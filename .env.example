# ============================================================
# 图像生成优化系统 — 环境变量配置
# 复制自 .env.example，填入真实密钥
# ============================================================

# --- Hugging Face 下载配置（国内必须，否则 CLIP 模型无法下载） ---
# HF_XET_HIGH_PERFORMANCE=1 启用高性能 Xet 传输（解决 xethub.hf.co 被墙问题）
# HF_HUB_DISABLE_SYMLINKS_WARNING=1 消除 Windows 下 symlink 警告
HF_XET_HIGH_PERFORMANCE=1
HF_HUB_DISABLE_SYMLINKS_WARNING=1

# # --- 豆包 / 火山方舟 (文生图) ---
# # 未设置时自动读取仓库根 .env 的 ARK_API_KEY / ARK_BASE_URL
 DOUBAO_API_KEY=
 DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# DOUBAO_IMAGE_MODEL=doubao-seedream-4-0-250828
# DOUBAO_IMAGE_SIZE=2048x2048


# --- 通义千问 / 百炼 (文生图) ---
TONGYI_API_KEY=
TONGYI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
TONGYI_IMAGE_MODEL=qwen-image-2.0-pro
TONGYI_IMAGE_SIZE=2048x2048

# --- LLM (用于 Prompt Refiner，兼容 OpenAI SDK) ---
# 不设置时自动使用仓库根 .env 的 ARK_API_KEY
LLM_API_KEY=
LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
LLM_MODEL=doubao-seed-2-0-lite-260215

# --- Milvus Standalone (Docker 部署) ---
# MILVUS_URI 优先级最高；未设置时自动拼接 http://MILVUS_HOST:MILVUS_PORT
# 使用 Docker 部署: docker compose up -d
# 端口 19531 与 picture2 项目的 19530 区分开，互不影响
MILVUS_URI=http://localhost:19531
MILVUS_HOST=localhost
MILVUS_PORT=19531

# --- VLM 复核（豆包视觉，纠正 CLIP missing 误判） ---
VLM_VERIFY_ENABLED=true
VLM_VISION_MODEL=doubao-seed-1-6-vision-250815
VLM_VERIFY_MAX_ATTRS=6
VLM_VERIFY_LANG=zh

# --- 本地 CLIP 模型（Chinese-CLIP ViT-Large Patch14 224） ---
# OFA-Sys/chinese-clip-vit-base-patch16: 512-dim 中英双语 CLIP
# 首次使用自动从 HuggingFace 下载 (~1.3GB)，可通过 HF_ENDPOINT 设置镜像
# 下为默认值，无需设置
CLIP_MODEL_NAME=OFA-Sys/chinese-clip-vit-base-patch16
# 推理设备: cpu (CPU 推理) / cuda (自动检测 GPU) / cuda:0 (指定 GPU)
# 留空或不设置时自动检测 CUDA → GPU 可用则 "cuda"，否则 "cpu"
CLIP_DEVICE=
# FP16 加速: true 显存减半 + 推理加速（RTX 3060 6GB 强烈建议开启）
# 留空时 CUDA 环境自动启用，CPU 自动关闭
CLIP_USE_FP16=true

# --- 动态分类体系（v6） ---
# 分类列表（逗号分隔，用于分区创建、API 返回、前端展示）
CATEGORIES=自然风光,人物人像,城市建筑,美食饮品,动植物,办公商务,数码科技,服饰穿搭,家居家装,节日庆典,手绘插画,纹理背景,交通出行,教育培训,运动休闲
# 分类中文名 → ASCII分区名映射（Milvus 分区名必须以字母或下划线开头）
CATEGORY_PARTITIONS=自然风光:ziranfengguang,人物人像:renwurenxiang,城市建筑:chengshijianzhu,美食饮品:meishiyinpin,动植物:dongzhiwu,办公商务:bangongshangwu,数码科技:shumakeji,服饰穿搭:fushichuanda,家居家装:jiajujiazhuang,节日庆典:jieriqingdian,手绘插画:shouhuichahua,纹理背景:wenlibeijing,交通出行:jiaotongchuxing,教育培训:jiaoyupeixun,运动休闲:yundongxiuxian

# --- 服务 ---
HOST=0.0.0.0
PORT=8001
# 图床对外可访问 URL 基址（不含尾斜杠）
PICTURE_ADMIN_PUBLIC_BASE_URL=http://localhost:8001

# --- 评测 / 终止规则 ---
VLM_EVAL_MODEL=doubao-seed-1-6-vision-250815
EVAL_THRESHOLD=0.82
# 分数较历史最佳下降超过此值时回滚 best_prompt 并停止
SCORE_ROLLBACK_DELTA=0.05
# 每轮 LLM 最多处理的 severe issue 数
MAX_ISSUES_PER_ROUND=3
CONVERGENCE_DELTA=0.01
# VLM promoted 属性占位分
VLM_PROMOTED_SCORE=0.45
