# ---- 环境变量（含 API 密钥，严禁入仓） ----
.env
.env.*
!.env.example

# ---- Python 缓存 ----
__pycache__/
*.pyc
*.pyo

# ---- pytest 缓存 ----
.pytest_cache/

# ---- 运行时数据（storage 目录） ----
storage/*
!storage/**/.gitkeep

# ---- Milvus 数据库文件 ----
storage/milvus_lite.db/
storage/milvus_data/

# ---- IDE / 编辑器 ----
.idea/
.vscode/

# ---- Claude Code / AI 工具产物 ----
.claude/

# ---- OS / 临时文件 ----
.DS_Store
Thumbs.db
*.swp
*.bak
*.tmp

# ---- 日志 ----
*.log

# ---- Node.js ----
node_modules/
dist/

# ---- 虚拟环境 ----
venv/
.venv/
